generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


username String @unique
email String @unique
password String 

//profile

displayName String 
bio String? @db.VarChar(160)
profilePicture String?
location String?
website String?

// Developer-specific fields
  skills String[] // PostgreSQL array for skills


//Relationships
posts Post[]
comments Comment[]
likes Like[]

// Following relationships (self-referential many-to-many)
  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")


//Notifications 
sendNotifications Notification[] @relation("NotificationSender")
recievedNotifications Notification[] @relation("NotificatoinRecipient")

@@map("users")
}

model Post{
      id        String   @id @default(cuid())
      createdAt DateTime @default(now())
      updatedAt DateTime @updatedAt

      //Content fields
      content String @db.Text
      images Json? //storing images and metadata in Json
      tags String[]

      codeSnippet Json?
}
